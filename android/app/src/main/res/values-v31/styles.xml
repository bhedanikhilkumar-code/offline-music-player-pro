<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ Splash Screen API override -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <!-- Set splash background to match our dark app theme -->
        <item name="android:windowSplashScreenBackground">@color/launch_background_color</item>
        <!-- Use a transparent/invisible icon so no icon appears -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <!-- Remove the animated icon brand bottom area -->
        <item name="android:windowSplashScreenBrandingImage">@null</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background_color</item>
    </style>
</resources>
