<?xml version="1.0" encoding="utf-8"?>
<!-- Widget 3: Full Player (4×3) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Album Art -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/widget_art_bg">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_widget_music"
            android:contentDescription="Album Art"/>
    </FrameLayout>

    <!-- Song Title -->
    <TextView
        android:id="@+id/widget_song_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="No song playing"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"/>

    <!-- Artist -->
    <TextView
        android:id="@+id/widget_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="Unknown Artist"
        android:textColor="#88FFFFFF"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <!-- Status -->
    <TextView
        android:id="@+id/widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="⏸ Paused"
        android:textColor="#FF6B35"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"/>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_btn_bg"
            android:contentDescription="Previous"
            android:padding="8dp"
            android:src="@drawable/ic_widget_prev"/>

        <ImageView
            android:id="@+id/widget_play_pause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/widget_btn_bg"
            android:contentDescription="Play/Pause"
            android:padding="10dp"
            android:src="@drawable/ic_widget_play"/>

        <ImageView
            android:id="@+id/widget_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_btn_bg"
            android:contentDescription="Next"
            android:padding="8dp"
            android:src="@drawable/ic_widget_next"/>
    </LinearLayout>
</LinearLayout>
