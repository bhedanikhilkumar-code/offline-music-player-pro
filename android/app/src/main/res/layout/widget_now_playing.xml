<?xml version="1.0" encoding="utf-8"?>
<!-- Widget 2: Now Playing (4×2) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Album Art Placeholder -->
    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/widget_art_bg">
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_widget_music"
            android:contentDescription="Album Art"/>
    </FrameLayout>

    <!-- Info + Controls -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/widget_song_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="No song playing"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Unknown Artist"
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

        <!-- Controls Row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/widget_prev"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/widget_btn_bg"
                android:contentDescription="Previous"
                android:padding="7dp"
                android:src="@drawable/ic_widget_prev"/>

            <ImageView
                android:id="@+id/widget_play_pause"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/widget_btn_bg"
                android:contentDescription="Play/Pause"
                android:padding="8dp"
                android:src="@drawable/ic_widget_play"/>

            <ImageView
                android:id="@+id/widget_next"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/widget_btn_bg"
                android:contentDescription="Next"
                android:padding="7dp"
                android:src="@drawable/ic_widget_next"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
